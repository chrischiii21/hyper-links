---
import RichTextCopier from '../components/RichTextCopier';
import ReportProcessor from '../components/ReportProcessor';
import ChangelogBanner from '../components/ChangelogBanner';
import '../styles/global.css';

// Fetch the latest commit on the server for immediate display
let latestCommitMessage = "System Update: Optimized Laboratory Performance";
try {
  const response = await fetch('https://api.github.com/repos/chrischiii21/hyper-links/commits?per_page=1', {
    headers: {
      'User-Agent': 'Astro-Server'
    }
  });
  if (response.ok) {
    const data = await response.json();
    if (data && data.length > 0) {
      latestCommitMessage = data[0].commit.message;
      console.log('Successfully fetched latest commit:', latestCommitMessage);
    }
  } else {
    console.error('Failed to fetch commit:', response.status, response.statusText);
  }
} catch (err) {
  console.error('Error fetching commit on server:', err);
}
---

<script>
	// Handle view switching with premium styles
	const copierBtn = document.getElementById('view-copier');
	const processorBtn = document.getElementById('view-processor');
	const copierView = document.getElementById('copier-view');
	const processorView = document.getElementById('processor-view');

	const setActive = (active: HTMLElement, inactive: HTMLElement) => {
		active.classList.add('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-100');
		active.classList.remove('text-slate-500', 'hover:text-slate-900', 'hover:bg-white/50');
		
		inactive.classList.remove('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-100');
		inactive.classList.add('text-slate-500', 'hover:text-slate-900', 'hover:bg-white/50');
	};

	copierBtn?.addEventListener('click', () => {
		copierView?.classList.remove('hidden');
		processorView?.classList.add('hidden');
		if (copierBtn && processorBtn) setActive(copierBtn, processorBtn);
	});

	processorBtn?.addEventListener('click', () => {
		processorView?.classList.remove('hidden');
		copierView?.classList.add('hidden');
		if (processorBtn && copierBtn) setActive(processorBtn, copierBtn);
	});
</script>

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Rich Text Copier & Report Processor</title>
    <meta name="description" content="Professional tools for link extraction, bullet sanitization, and research report processing." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="antialiased min-h-screen bg-slate-50 font-sans">
		<ChangelogBanner client:load message={latestCommitMessage} />

		<nav class="sticky top-[40px] z-50 py-6 px-4">
			<div class="max-w-6xl mx-auto">
				<div class="flex flex-col md:flex-row items-center justify-between gap-6 bg-white/70 backdrop-blur-xl border border-white/40 p-3 pr-4 rounded-[2rem] shadow-premium">
					<div class="flex items-center gap-4 px-4">
						<div class="w-11 h-11 bg-indigo-600 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-200 rotate-3 transition-transform hover:rotate-0 cursor-default">
							<span class="text-white font-black text-xl tracking-tighter italic">H</span>
						</div>
						<div>
							<h1 class="font-black text-xl tracking-tight text-slate-900 leading-none">Hyperlinks</h1>
							<p class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mt-1">Director's Suite</p>
						</div>
					</div>
					
					<div class="flex items-center gap-1 bg-slate-900/5 p-1.5 rounded-2xl border border-slate-900/5">
						<button 
							id="view-copier"
							class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all duration-300 bg-indigo-600 text-white shadow-lg shadow-indigo-100 flex items-center gap-2 premium-button"
						>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
							Text Copier
						</button>
						<button 
							id="view-processor"
							class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all duration-300 text-slate-500 hover:text-slate-900 hover:bg-white/50 flex items-center gap-2 premium-button"
						>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
							Report Processor
						</button>
					</div>
				</div>
			</div>
		</nav>

		<main class="pb-20">
			<div id="copier-view">
				<RichTextCopier client:load />
			</div>
			<div id="processor-view" class="hidden">
				<ReportProcessor client:load />
			</div>
		</main>
	</body>
</html>
