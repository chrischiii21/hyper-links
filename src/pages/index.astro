---
import ReportProcessor from '../components/ReportProcessor';
import LinkExtractor from '../components/LinkExtractor';
import SanitizeBullets from '../components/SanitizeBullets';
import ChangelogBanner from '../components/ChangelogBanner';
import '../styles/global.css';

// Fetch the latest commit on the server for immediate display
let latestCommitMessage = "System Update: Optimized Laboratory Performance";
try {
  const response = await fetch('https://api.github.com/repos/chrischiii21/hyper-links/commits?per_page=1', {
    headers: {
      'User-Agent': 'Astro-Server'
    }
  });
  if (response.ok) {
    const data = await response.json();
    if (data && data.length > 0) {
      latestCommitMessage = data[0].commit.message;
      console.log('Successfully fetched latest commit:', latestCommitMessage);
    }
  } else {
    console.error('Failed to fetch commit:', response.status, response.statusText);
  }
} catch (err) {
  console.error('Error fetching commit on server:', err);
}
---

<script>
	// Handle view switching with premium styles
	const tabs = [
		{ button: 'view-processor', view: 'processor-view' },
		{ button: 'view-linkextractor', view: 'linkextractor-view' },
		{ button: 'view-sanitize', view: 'sanitize-view' }
	];

	const activate = (button: HTMLElement) => {
		button.classList.add('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-100');
		button.classList.remove('text-slate-500', 'hover:text-slate-900', 'hover:bg-white/50');
	};

	const deactivate = (button: HTMLElement) => {
		button.classList.remove('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-100');
		button.classList.add('text-slate-500', 'hover:text-slate-900', 'hover:bg-white/50');
	};

	const switchTo = (targetButtonId: string) => {
		tabs.forEach(({ button, view }) => {
			const buttonEl = document.getElementById(button);
			const viewEl = document.getElementById(view);
			if (!buttonEl || !viewEl) return;

			if (button === targetButtonId) {
				viewEl.classList.remove('hidden');
				activate(buttonEl);
			} else {
				viewEl.classList.add('hidden');
				deactivate(buttonEl);
			}
		});
	};

	tabs.forEach(({ button }) => {
		document.getElementById(button)?.addEventListener('click', () => switchTo(button));
	});
</script>

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Hyperlinks - File Ingestion, Link Extractor & Sanitize Bullets</title>
    <meta name="description" content="Professional tools for link extraction, bullet sanitization, and research report processing." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="antialiased min-h-screen bg-slate-50 font-sans">
		<ChangelogBanner client:load message={latestCommitMessage} />

		<nav class="sticky top-[40px] z-50 bg-white/70 backdrop-blur-xl border-b border-slate-200/60 py-3 px-6">
			<div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
				<div class="flex items-center gap-4">
					<div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center shadow-lg shadow-indigo-100 rotate-3 transition-transform hover:rotate-0 cursor-default">
						<span class="text-white font-black text-lg tracking-tighter italic">H</span>
					</div>
					<div>
						<h1 class="font-black text-lg tracking-tight text-slate-900 leading-none">Hyperlinks</h1>
					</div>
				</div>
				
				<div class="flex items-center gap-1 bg-slate-900/5 p-1 rounded-xl border border-slate-900/5">
					<button
						id="view-processor"
						class="px-5 py-2 rounded-lg text-xs font-bold transition-all duration-300 bg-indigo-600 text-white shadow-lg shadow-indigo-100 flex items-center gap-2 premium-button"
					>
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
						File Ingestion
					</button>
					<button
						id="view-linkextractor"
						class="px-5 py-2 rounded-lg text-xs font-bold transition-all duration-300 text-slate-500 hover:text-slate-900 hover:bg-white/50 flex items-center gap-2 premium-button"
					>
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
						Link Extractor
					</button>
					<button
						id="view-sanitize"
						class="px-5 py-2 rounded-lg text-xs font-bold transition-all duration-300 text-slate-500 hover:text-slate-900 hover:bg-white/50 flex items-center gap-2 premium-button"
					>
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
						Sanitize Bullets
					</button>
				</div>
			</div>
		</nav>

		<main class="pt-14 pb-20">
			<div id="processor-view">
				<ReportProcessor client:load />
			</div>
			<div id="linkextractor-view" class="hidden">
				<LinkExtractor client:load />
			</div>
			<div id="sanitize-view" class="hidden">
				<SanitizeBullets client:load />
			</div>
		</main>

		<!-- Floating Back to Top Button -->
		<button 
			id="back-to-top" 
			class="fixed bottom-8 right-8 p-4 bg-indigo-600 text-white rounded-full shadow-2xl shadow-indigo-200 opacity-0 invisible translate-y-4 transition-all duration-500 z-[100] hover:bg-indigo-700 hover:-translate-y-1 active:scale-90 group"
			aria-label="Back to Top"
		>
			<svg class="w-6 h-6 transition-transform group-hover:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
			</svg>
		</button>

		<script>
			const backToTopBtn = document.getElementById('back-to-top');

			// Show/hide button on scroll
			window.addEventListener('scroll', () => {
				if (window.scrollY > 300) {
					backToTopBtn?.classList.remove('opacity-0', 'invisible', 'translate-y-4');
					backToTopBtn?.classList.add('opacity-100', 'visible', 'translate-y-0');
				} else {
					backToTopBtn?.classList.add('opacity-0', 'invisible', 'translate-y-4');
					backToTopBtn?.classList.remove('opacity-100', 'visible', 'translate-y-0');
				}
			});

			// Scroll to top on click
			backToTopBtn?.addEventListener('click', () => {
				window.scrollTo({
					top: 0,
					behavior: 'smooth'
				});
			});
		</script>
	</body>
</html>
